# Scaleway API
SCW_SECRET_KEY=your-scaleway-secret-key
SCW_PROJECT_ID=your-project-id

# Scaleway Generative APIs
SCW_GENERATIVE_API_URL=https://api.scaleway.ai/v1

# Scaleway Managed Inference (BGE embeddings)
SCW_INFERENCE_ENDPOINT=https://<deployment-uuid>.ifr.fr-par.scaleway.com/v1

# PostgreSQL (from tofu output)
DATABASE_URL=postgresql://lab_user:password@host:port/medical_knowledge

# Object Storage
SCW_S3_ENDPOINT=https://s3.fr-par.scw.cloud
SCW_S3_BUCKET=medical-lab-docs
SCW_ACCESS_KEY=your-access-key
