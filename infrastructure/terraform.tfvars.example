# Scaleway Medical AI Lab - Example Variables
# Copy this file to terraform.tfvars and fill in your values (OpenTofu uses the same file names):
#   cp terraform.tfvars.example terraform.tfvars

access_key      = "SCWXXXXXXXXXXXXXXXXX"
secret_key      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
organization_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
project_id      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Custom domain name (optional).
# When set: uses your domain for TLS (requires a DNS A record pointing to the LB IP).
# When empty (default): auto-generates a sslip.io domain from the LB IP for free TLS.
# domain_name = "lab.example.com"
