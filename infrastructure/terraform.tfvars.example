# Scaleway Medical AI Lab — credentials
# See QUICKSTART.md for a step-by-step walkthrough.
#
# Copy this file, then fill in the four values below:
#   cp terraform.tfvars.example terraform.tfvars

access_key      = "SCWXXXXXXXXXXXXXXXXX"                   # console.scaleway.com/iam  →  API keys  →  Generate
secret_key      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"   # shown once, alongside the access key
organization_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"   # console.scaleway.com/organization  →  Copy ID
project_id      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"   # Project Dashboard  →  Copy ID

# Optional — custom domain for TLS (requires a DNS A record pointing at the LB IP).
# Leave commented out to auto-generate a free sslip.io domain from the LB IP.
# domain_name = "lab.example.com"
