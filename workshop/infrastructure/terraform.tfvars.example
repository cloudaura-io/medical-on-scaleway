# Scaleway credentials (get these from console.scaleway.com -> IAM -> API Keys)
access_key      = "SCW..."
secret_key      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
organization_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
project_id      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Optional: SSH public key for admin access to the instance.
# The workshop works over HTTPS only, SSH is only useful for debugging.
# ssh_public_key = "ssh-ed25519 AAAA..."

# Optional: custom domain name for TLS.
# When set: uses your domain (requires DNS A record pointing at the instance IP).
# When empty (default): auto-generates a sslip.io hostname and gets free Let's Encrypt TLS.
# domain_name = "workshop-student01.example.com"

# Optional: public repo the JupyterLab VM git-clones on first boot.
# Unset means JupyterLab boots empty with no workshop content.
# workshop_repo_url = "https://github.com/cloudaura-io/medical-on-scaleway.git"
